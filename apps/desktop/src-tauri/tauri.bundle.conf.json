{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeBuildCommand": "pnpm sidecar:prepare && pnpm build"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "shortDescription": "A local-first AI coding companion",
    "longDescription": "Sigil desktop runs one private local Sigil server per workspace and keeps approvals, verification, and durable sessions under the same runtime contracts as the terminal application.",
    "externalBin": ["binaries/sigil-runtime"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
