            "type": "string"
          },
          "step_id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "workspace_snapshot_id": {
            "type": "string"
          }
        },
        "required": [
          "task_id",
          "step_id",
          "check_spec_id",
          "check_spec_hash",
          "policy_hash",
          "workspace_snapshot_id"
        ],
        "type": "object"
      },
      "VerificationReviewApprovalAction": {
        "properties": {
          "kind": {
            "const": "review_approval",
            "type": "string"
          },
          "request": {
            "properties": {
              "check_spec_id": {
                "type": "string"
              }
            },
            "required": [
              "check_spec_id"
            ],
            "type": "object"
          }
        },
        "required": [
          "kind",
          "request"
        ],
        "type": "object"
      },
      "VerificationVerdict": {
        "enum": [
          "not_evaluated",
          "not_applicable",
          "pending",
          "passed",
          "failed",
          "missing",
          "inconclusive",
          "stale",
          "skipped"
        ],
        "type": "string"
      },
      "VerificationView": {
        "properties": {
          "action": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/VerificationRerunAction"
              },
              {
                "$ref": "#/components/schemas/VerificationReviewApprovalAction"
              },
              {
                "type": "null"
              }
            ]
          },
          "evidence": {
            "$ref": "#/components/schemas/VerificationEvidence"
          },
          "recommendation_kind": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/VerificationRecommendationKind"
              },
              {
                "type": "null"
              }
            ]
          },
          "recommendation_reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "recommended_check_spec_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "scope": {
            "$ref": "#/components/schemas/EvidenceScope"
          },
          "status": {
            "type": "string"
          },
          "step_id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "verdict": {
            "$ref": "#/components/schemas/VerificationVerdict"
          }
        },
        "required": [
          "task_id",
          "step_id",
          "scope",
          "verdict",
          "status",
          "recommended_check_spec_id",
          "recommendation_kind",
          "recommendation_reason",
          "action",
          "evidence"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Localhost-only adapter surface for desktop and future local clients.",
    "title": "Sigil Local App Server API",
    "version": "0.0.1-alpha.5"
  },
  "openapi": "3.1.0",
  "paths": {
    "/disclosures": {
      "get": {
        "parameters": [
          {
            "in": "header",
            "name": "Last-Event-ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisclosureListResponse"
                }
              }
            },
            "description": "Retained disclosure suffix"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "Replay safe durable egress disclosures"
      }
    },
    "/health": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Listener is running"
          }
        },
        "security": [],
        "summary": "Local listener health check"
      }
    },
    "/openapi.json": {
      "get": {
        "responses": {
          "200": {
            "description": "OpenAPI 3.1 document"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Read this authenticated local API description"
      }
    },
    "/runs/{run_id}": {
      "get": {
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunSnapshot"
                }
              }
            },
            "description": "Run snapshot"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "summary": "Get a run snapshot"
      }
    },
    "/runs/{run_id}/approvals/{call_id}": {
      "post": {
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          },
          {
            "$ref": "#/components/parameters/CallId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApprovalDecisionCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApprovalCommandReceipt"
                }
              }
            },
            "description": "Approval command receipt"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "Submit an approval decision for a pending tool call"
      }
    },
    "/runs/{run_id}/cancel": {
      "post": {
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunCancelCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunCancelCommandReceipt"
                }
              }
            },
            "description": "Run-cancel command receipt"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "Request run cancellation"
      }
    },
    "/runs/{run_id}/events": {
      "get": {
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          },
          {
            "in": "header",
            "name": "Last-Event-ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Continuous text/event-stream until terminal, disconnect, lag, or shutdown"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        },
        "summary": "Replay durable run events then follow live events"
      }
    },
    "/server-info": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerInfo"
                }
              }
            },
            "description": "Secret-free workspace/listener/protocol capabilities"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "Read immutable local server bootstrap metadata"
      }
    },
    "/session-catalog": {
      "get": {
        "description": "Reconciles the rebuildable SQLite projection from durable JSONL sources, then returns a generation-consistent keyset page. Active run, approval, and progress state are not included.",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Literal case-insensitive title search",
            "in": "query",
            "name": "q",
            "required": false,
            "schema": {
              "maxLength": 160,
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "provider",
            "required": false,
            "schema": {
              "maxLength": 128,
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "pinned",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "in": "query",
            "name": "state",
            "required": false,
            "schema": {
              "enum": [
                "ready",
                "oversized",
                "scan_budget_exceeded",
                "unsupported_legacy",
                "invalid"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionCatalogPage"
                }
              }
            },
            "description": "Generation-consistent historical session page"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "List durable historical sessions for the current workspace"
      }
    },
    "/sessions": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionListResponse"
                }
              }
            },
            "description": "Session list"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "List local session handles"
      },
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionSnapshot"
                }
              }
            },
            "description": "Session snapshot"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "summary": "Create a local session handle"
      }
    },
    "/sessions/open": {
      "post": {
        "description": "Revalidates the relative session reference and expected durable identity against current lifecycle and JSONL truth. SQLite catalog rows are candidates, not authorization.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionOpenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionSnapshot"
                }
              }
            },
            "description": "New or existing idempotent local session snapshot"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "Reopen a durable workspace session as a local handle"
      }
    },
    "/sessions/{session_id}": {
      "get": {
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionSnapshot"
                }
              }
            },
            "description": "Session snapshot"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "summary": "Get a local session handle"
      }
    },
    "/sessions/{session_id}/runs": {
      "post": {
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunStartCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunStartCommandReceipt"
                }
              }
            },
            "description": "Run-start command receipt"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "Start a run in a session"
      }
    },
    "/sessions/{session_id}/transcript": {
      "get": {
        "description": "Projects user, assistant and tool-result text from scope-checked append-only session truth. System/control entries, tool arguments, resolved image bytes and server-private paths are excluded.",
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Exclusive one-based message ordinal for the next older page",
            "in": "query",
            "name": "before",
            "required": false,
            "schema": {
              "format": "uint64",
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionTranscriptPage"
                }
              }
            },
            "description": "Bounded transcript page in chronological order"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "summary": "Read one bounded chronological page of durable conversation messages"
      }
    },
    "/sessions/{session_id}/verification": {
      "get": {
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationView"
                }
              }
            },
            "description": "Shared verification product projection"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "summary": "Project the current task verification recommendation and evidence"
      }
    },
    "/sessions/{session_id}/verification/rerun": {
      "post": {
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerificationRerunCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationRerunCommandReceipt"
                }
              }
            },
            "description": "Durable verification rerun receipt"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        },
        "summary": "Rerun one exact stale-safe recommended verification check"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
