{
  "components": {
    "parameters": {
      "CallId": {
        "in": "path",
        "name": "call_id",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "RunId": {
        "in": "path",
        "name": "run_id",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "SessionId": {
        "in": "path",
        "name": "session_id",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Invalid request body or command payload"
      },
      "Conflict": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Command is stale, mismatched, expired, or not pending"
      },
      "InternalError": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Session binding, driver routing, or command completion failed"
      },
      "NotFound": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Session, run, or route was not found"
      },
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Bearer token is missing or invalid"
      },
      "Unavailable": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "The durable command identity store is unavailable or at capacity"
      }
    },
